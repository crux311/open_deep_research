OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=
RAINDROP_LOCAL_DEBUGGER=http://localhost:5899/v1/
RAINDROP_WRITE_KEY=

# Cost-conscious local defaults. Override these in LangGraph Studio as needed.
SEARCH_API=openai
MAX_CONCURRENT_RESEARCH_UNITS=2
MAX_RESEARCHER_ITERATIONS=3
MAX_REACT_TOOL_CALLS=4

# Only necessary for Open Agent Platform
SUPABASE_KEY=
SUPABASE_URL=
# Should be set to true for a production deployment on Open Agent Platform. Should be set to false otherwise, such as for local development.
GET_API_KEYS_FROM_CONFIG=false
